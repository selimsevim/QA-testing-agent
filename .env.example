# InboxFlow Agent — Environment Configuration
# Copy to .env and fill in values you need.
# DEMO MODE works without any of these set.

# Server mode: "demo" or "live". Defaults to demo.
APP_MODE=live

# Server port (default 4000)
PORT=4000

# Gemini API key (optional — falls back to deterministic logic if unset)
GEMINI_API_KEY=

# Gemini model — defaults to gemini-2.5-pro for reasoning quality.
# Override to gemini-2.5-flash if you want faster, cheaper calls.
GEMINI_MODEL=gemini-2.5-pro

# Google OAuth — required only for real Gmail mode
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/gmail/oauth/callback

# Frontend URL used for OAuth callback redirect
CLIENT_URL=http://localhost:5173

# SFMC Marketing Cloud REST + Auth (required for the demo to fire real entry events)
# Subdomain — same prefix used by both the auth and REST endpoints
# e.g.  https://<SFMC_SUBDOMAIN>.auth.marketingcloudapis.com/v2/token
#       https://<SFMC_SUBDOMAIN>.rest.marketingcloudapis.com/interaction/v1/events
SFMC_SUBDOMAIN=
SFMC_CLIENT_ID=
SFMC_CLIENT_SECRET=
SFMC_ACCOUNT_ID=
