# InboxFlow Agent — Environment Configuration
# Copy to .env and fill in values you need.
# Server port (default 4000)
PORT=4000

# Optional display/filter label for the Gmail seed account.
# If empty, the connected Gmail account email is shown in the UI.
SEED_INBOX=

# Gemini API key (optional; falls back to deterministic logic if unset)
GEMINI_API_KEY=

# Gemini model. Defaults to gemini-2.5-pro for reasoning quality.
# Override to gemini-2.5-flash if you want faster, cheaper calls.
GEMINI_MODEL=gemini-2.5-pro

# Google OAuth, required for Gmail access.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI2=http://localhost:4000/api/gmail/oauth/callback

# Frontend URL used for OAuth callback redirect
CLIENT_URL2=http://localhost:5173
